{
  "name": "vue-lottie-player",
  "version": "2.0.0",
  "description": "Lottie Animation Player for Vue",
  "author": "turopoff",
  "license": "MIT",
  "private": false,
  "scripts": {
    "build": "vite build && vite build --config vite.full.config.mjs && vue-tsc --emitDeclarationOnly --outDir dist",
    "typecheck": "vue-tsc --noEmit",
    "dev:vue": "npm run dev --prefix examples/vue",
    "build:vue": "npm run build --prefix examples/vue",
    "preview:vue": "npm run preview --prefix examples/vue"
  },
  "dependencies": {
    "lottie-web": "^5.13.0"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "typescript": "^5.9.3",
    "vite": "^6.4.2",
    "vue-tsc": "^3.1.1",
    "vue": "^3.5.32"
  },
  "keywords": [
    "vuejs",
    "lottie",
    "vue-lottie",
    "lottie-vue",
    "lottie-web",
    "web-lottie",
    "lottie-player",
    "player-lottie",
    "vue-lottie-player",
    "lottie-player-vue",
    "player-lottie-vue",
    "vue-component",
    "vue-animation",
    "lottiefiles"
  ],
  "main": "./dist/vue-lottie-player.cjs",
  "module": "./dist/vue-lottie-player.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/vue-lottie-player.css",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vue-lottie-player.js",
      "require": "./dist/vue-lottie-player.cjs"
    },
    "./full": {
      "types": "./dist/full-index.d.ts",
      "import": "./dist/full.js",
      "require": "./dist/full.cjs"
    },
    "./style.css": "./dist/vue-lottie-player.css",
    "./full/style.css": "./dist/vue-lottie-player.css",
    "./dist/style.css": "./dist/vue-lottie-player.css",
    "./dist/vue-lottie-player.css": "./dist/vue-lottie-player.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/turopoff/vue-lottie-player.git"
  }
}
